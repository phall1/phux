{
  "name": "@phux/pi",
  "version": "0.1.0",
  "description": "Pi integration for controlling shared phux terminals",
  "private": true,
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/phall1/phux.git",
    "directory": "integrations/pi"
  },
  "keywords": [
    "pi-package",
    "phux",
    "terminal"
  ],
  "files": [
    "dist",
    "extensions/index.ts",
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./adapter": {
      "types": "./dist/src/adapter.d.ts",
      "import": "./dist/src/adapter.js"
    }
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:test": "npm run clean && tsc -p tsconfig.test.json",
    "test": "npm run test:unit && npm run pack:check && npm run smoke:load",
    "test:unit": "npm run build:test && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm run build && node scripts/test-pack.mjs",
    "smoke:load": "npm run build && node scripts/test-extension-load.mjs",
    "smoke:real": "node scripts/smoke-real.mjs",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@earendil-works/pi-tui": "^0.80.7",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
