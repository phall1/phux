#!/bin/bash
set -euo pipefail

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/../.." && pwd)
PHUX_BIN=${PHUX:-"$ROOT/target/debug/phux"}
PI_EXTENSION=${PHUX_PI_EXTENSION:-"$ROOT/integrations/pi/extensions/index.ts"}
PI_MODEL=${PI_MODEL:-openai-codex/gpt-5.6-sol}
RUNTIME_DIR=$(mktemp -d "${TMPDIR:-/tmp}/phux-pi-proof-runtime.XXXXXX")
SOCKET="$RUNTIME_DIR/phux.sock"
SERVER_LOG="$RUNTIME_DIR/server.log"
RAW_EVENTS="$RUNTIME_DIR/pi.jsonl"
WORKDIR=$(mktemp -d "${TMPDIR:-/tmp}/phux-pi-proof-work.XXXXXX")
SESSION="pi-live-proof-$$"
export PATH="$(dirname "$PHUX_BIN"):$PATH"
export PHUX_SOCKET="$SOCKET"

cleanup() {
  kill "${SERVER_PID:-}" 2>/dev/null || true
  wait "${SERVER_PID:-}" 2>/dev/null || true
  rm -rf "$RUNTIME_DIR" "$WORKDIR"
}
trap cleanup EXIT

for command in "$PHUX_BIN" pi node jq; do
  command -v "$command" >/dev/null || { echo "missing required command: $command" >&2; exit 1; }
done
[[ -f "$PI_EXTENSION" ]] || { echo "missing Pi extension: $PI_EXTENSION" >&2; exit 1; }

(cd "$WORKDIR" && exec "$PHUX_BIN" server) >"$SERVER_LOG" 2>&1 &
SERVER_PID=$!
for _ in $(seq 1 100); do
  [[ -S "$SOCKET" ]] && break
  sleep 0.05
done
[[ -S "$SOCKET" ]] || { echo "phux server failed to start; see $SERVER_LOG" >&2; exit 1; }

cat <<EOF
PHUX + PI LIVE FLEET PROOF
==========================
Pi model: $PI_MODEL
Server: isolated local Unix socket
Fleet: real Claude Code + real OpenAI Codex
Contract: canonical phux CLI through the @phux/pi extension
Session: $SESSION
EOF

PROMPT=$(cat <<EOF
Act as the Pi fleet orchestrator and complete this live proof. Use only the supplied phux tools; do not use shell or builtin tools.

1. Create session "$SESSION" in "$WORKDIR" with command ["sh","-lc","exec zsh -f"]. Remember the exact seed selector returned.
2. Launch integration "claude-code" in cwd "$WORKDIR" beside that exact seed, split vertical, ratio 0.55, alias "claude", with extra ["--dangerously-skip-permissions"].
3. Launch integration "codex" in cwd "$WORKDIR" beside alias:claude, split horizontal, ratio 0.5, alias "codex", with extra ["--dangerously-bypass-approvals-and-sandbox"].
4. Use bounded watch or wait calls so both real agent TUIs have initialized, and inspect each snapshot.
5. Send this literal text to alias:claude without Enter: "Reply only with the underscore token formed from CLAUDE LIVE FLEET OK. Do not use tools." Then make a separate phux_send_keys call containing only ["Enter"].
6. Send this literal text to alias:codex without Enter: "Reply only with the underscore token formed from CODEX LIVE FLEET OK. Do not use tools." Then make a separate phux_send_keys call containing only ["Enter"].
7. Wait up to 180 seconds for CLAUDE_LIVE_FLEET_OK and CODEX_LIVE_FLEET_OK respectively. The underscore result tokens do not occur in the prompts. If an agent returns the wrong token, inspect it, correct the prompt, and verify again.
8. Prove spatial control by swapping alias:claude and alias:codex.
9. Inventory all panes, then capture a rendered 120x32 snapshot of session "$SESSION".
10. Finish only after both result tokens are visibly present. Summarize the exact selectors and state LIVE_PI_PHUX_FLEET_OK. Do not kill the panes; the outer proof harness cleans up after independent verification.

If a transient startup condition occurs, inspect and retry safely. Never claim success without both exact output tokens.
EOF
)

pi --mode json --print --no-session --no-extensions \
  --model "$PI_MODEL" \
  --extension "$PI_EXTENSION" \
  --no-builtin-tools \
  --tools phux_create,phux_launch,phux_snapshot,phux_send_keys,phux_wait,phux_watch_events,phux_swap_pane,phux_panes,phux_rendered_snapshot,phux_targets \
  --no-skills --no-prompt-templates --no-context-files \
  "$PROMPT" | tee "$RAW_EVENTS" | node "$ROOT/examples/agents/pi-proof-formatter.mjs"

grep -q 'CLAUDE_LIVE_FLEET_OK' "$RAW_EVENTS"
grep -q 'CODEX_LIVE_FLEET_OK' "$RAW_EVENTS"
grep -q 'LIVE_PI_PHUX_FLEET_OK' "$RAW_EVENTS"

printf '\nIndependent CLI verification\n----------------------------\n'
"$PHUX_BIN" agent list --json | jq -r '.agents[] | select(.session == "'"$SESSION"'") | "\(.terminal)  agent=\(.agent.id)  kind=\(.agent.kind)  state=\(.state)"'
printf '\nRecorded proof complete; isolated server will now be cleaned up.\n'
